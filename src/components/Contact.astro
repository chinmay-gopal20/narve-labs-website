---
---

<section class="contact" id="cta" aria-labelledby="contact-heading">
  <div class="contact-inner">

    <div class="contact-header">
      <h2 id="contact-heading" class="reveal">Let's <em>Talk.</em></h2>
      <p class="reveal">Tell us what you're building. We'll reach out within 24 hours.</p>
    </div>

    <form id="contact-form" class="contact-form reveal" novalidate>
      <!-- Honeypot: bots fill this, humans don't -->
      <input type="text" name="website" tabindex="-1" autocomplete="off" class="hp-field" aria-hidden="true" />

      <div class="form-row">
        <div class="form-field">
          <label for="cf-name">Name</label>
          <input type="text" id="cf-name" name="name" placeholder="Your name" autocomplete="name" />
          <p class="field-error" id="err-name" role="alert"></p>
        </div>
        <div class="form-field">
          <label for="cf-email">Email</label>
          <input type="email" id="cf-email" name="email" placeholder="you@company.com" autocomplete="email" />
          <p class="field-error" id="err-email" role="alert"></p>
        </div>
      </div>

      <div class="form-field">
        <div class="label-row">
          <label for="cf-message">What are you looking to build?</label>
          <span class="char-counter" id="char-counter">0 / 1000</span>
        </div>
        <textarea
          id="cf-message"
          name="message"
          placeholder="Tell us about your project — the problem you're solving, what you've tried, what success looks like."
          rows="5"
        ></textarea>
        <p class="field-error" id="err-message" role="alert"></p>
      </div>

      <div class="form-footer">
        <button type="submit" class="btn-submit" id="submit-btn">
          <span class="btn-text">Send it →</span>
          <span class="btn-spinner" aria-hidden="true"></span>
        </button>
        <p class="micro">No pitch decks. No pressure.</p>
      </div>

      <p class="form-error" id="form-error" role="alert"></p>
    </form>

    <div class="contact-success" id="contact-success" aria-live="polite">
      <div class="success-icon" aria-hidden="true">✓</div>
      <h3>We got it.</h3>
      <p>Expect a reply within 24 hours.<br />Talk soon.</p>
    </div>

  </div>
</section>

<script>
  const WEBHOOK_URL = import.meta.env.PUBLIC_MAKE_WEBHOOK_URL;

  const MSG_MIN = 30;
  const MSG_MAX = 1000;

  const form     = document.getElementById('contact-form') as HTMLFormElement;
  const successEl = document.getElementById('contact-success') as HTMLElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const globalErr = document.getElementById('form-error') as HTMLElement;
  const charCounter = document.getElementById('char-counter') as HTMLElement;

  const nameInput    = document.getElementById('cf-name') as HTMLInputElement;
  const emailInput   = document.getElementById('cf-email') as HTMLInputElement;
  const messageInput = document.getElementById('cf-message') as HTMLTextAreaElement;

  // ── Validators ──────────────────────────────────────────────

  function validateName(): string {
    const v = nameInput.value.trim();
    if (!v) return 'Name is required.';
    if (v.length < 2) return 'Name must be at least 2 characters.';
    return '';
  }

  function validateEmail(): string {
    const v = emailInput.value.trim();
    if (!v) return 'Email is required.';
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(v)) return 'Enter a valid email address.';
    return '';
  }

  function validateMessage(): string {
    const v = messageInput.value.trim();
    if (!v) return 'Tell us what you\'re building.';
    if (v.length < MSG_MIN) return `At least ${MSG_MIN} characters needed (${MSG_MIN - v.length} more to go).`;
    if (v.length > MSG_MAX) return `Keep it under ${MSG_MAX} characters.`;
    return '';
  }

  // ── Show / clear inline errors ───────────────────────────────

  function setError(el: HTMLElement, input: HTMLElement, msg: string) {
    el.textContent = msg;
    if (msg) {
      input.classList.add('invalid');
    } else {
      input.classList.remove('invalid');
    }
  }

  // ── Blur listeners (validate on leave) ──────────────────────

  nameInput.addEventListener('blur', () =>
    setError(document.getElementById('err-name')!, nameInput, validateName()));

  emailInput.addEventListener('blur', () =>
    setError(document.getElementById('err-email')!, emailInput, validateEmail()));

messageInput.addEventListener('blur', () =>
    setError(document.getElementById('err-message')!, messageInput, validateMessage()));

  // Clear error as soon as user starts fixing the field
  [nameInput, emailInput, messageInput].forEach(input => {
    input.addEventListener('input', () => {
      input.classList.remove('invalid');
      const errId = 'err-' + input.name;
      const errEl = document.getElementById(errId);
      if (errEl) errEl.textContent = '';
    });
  });

  // ── Live character counter ────────────────────────────────────

  messageInput.addEventListener('input', () => {
    const len = messageInput.value.length;
    charCounter.textContent = `${len} / ${MSG_MAX}`;
    charCounter.classList.toggle('counter-warn', len > MSG_MAX || (len > 0 && len < MSG_MIN));
    charCounter.classList.toggle('counter-ok', len >= MSG_MIN && len <= MSG_MAX);
  });

  // ── Submit ────────────────────────────────────────────────────

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const honeypot = form.querySelector<HTMLInputElement>('[name="website"]');
    if (honeypot?.value) return;

    // Run all validators and show errors
    const nameErr    = validateName();
    const emailErr   = validateEmail();
    const messageErr = validateMessage();

    setError(document.getElementById('err-name')!,    nameInput,    nameErr);
    setError(document.getElementById('err-email')!,   emailInput,   emailErr);
    setError(document.getElementById('err-message')!, messageInput, messageErr);

    if (nameErr || emailErr || messageErr) return;

    const params = new URLSearchParams(window.location.search);

    const payload = {
      name:         nameInput.value.trim(),
      email:        emailInput.value.trim(),
      message:      messageInput.value.trim(),
      utm_source:   params.get('utm_source') || 'direct',
      utm_medium:   params.get('utm_medium') || '',
      utm_campaign: params.get('utm_campaign') || '',
      referrer:     document.referrer || '',
      submitted_at: new Date().toISOString(),
    };

    submitBtn.classList.add('loading');
    submitBtn.disabled = true;
    globalErr.textContent = '';

    try {
      await fetch(WEBHOOK_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      form.style.display = 'none';
      successEl.classList.add('visible');
    } catch {
      submitBtn.classList.remove('loading');
      submitBtn.disabled = false;
      globalErr.textContent = 'Something went wrong. Please try again.';
    }
  });
</script>

<style>
  .contact {
    background: var(--color-ink);
    color: #fff;
    padding: clamp(100px, 14vw, 180px) clamp(24px, 5vw, 72px);
    position: relative;
    overflow: hidden;
  }

  .contact::before {
    content: '';
    position: absolute;
    bottom: -40%;
    left: 50%;
    transform: translateX(-50%);
    width: 80vw;
    height: 80vw;
    max-width: 1000px;
    max-height: 1000px;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.2), transparent 62%);
    pointer-events: none;
  }

  .contact-inner {
    position: relative;
    z-index: 1;
    max-width: 780px;
    margin: 0 auto;
  }

  .contact-header {
    text-align: center;
    margin-bottom: clamp(48px, 6vw, 72px);
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(44px, 8vw, 100px);
    letter-spacing: -0.035em;
    line-height: 1;
    margin-bottom: 20px;
  }

  h2 em {
    font-style: normal;
    color: var(--color-purple-mid);
  }

  .contact-header p {
    font-size: clamp(16px, 1.5vw, 18px);
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.65;
  }

  /* ── Form ── */

  .hp-field {
    display: none;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 560px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .label-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  label {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .char-counter {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.3);
    font-variant-numeric: tabular-nums;
    transition: color 0.2s;
  }

  .char-counter.counter-warn { color: #f87171; }
  .char-counter.counter-ok   { color: #86efac; }

  input,
  textarea {
    font-family: var(--font-body);
    font-size: 15px;
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
    border: 1.5px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 15px 18px;
    width: 100%;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    resize: none;
  }

  input::placeholder,
  textarea::placeholder {
    color: rgba(255, 255, 255, 0.25);
  }

  input:focus,
  textarea:focus {
    border-color: var(--color-purple-mid);
    background: rgba(124, 58, 237, 0.08);
  }

  input.invalid,
  textarea.invalid {
    border-color: #f87171;
    background: rgba(248, 113, 113, 0.06);
  }

  textarea {
    min-height: 140px;
    line-height: 1.6;
  }

  .field-error {
    font-size: 13px;
    color: #f87171;
    min-height: 18px;
    line-height: 1.4;
  }

  /* ── Footer row ── */

  .form-footer {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .btn-submit {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    color: #fff;
    background: var(--color-purple);
    border: none;
    padding: 17px 36px;
    border-radius: 100px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.25s, background 0.25s;
    box-shadow: 0 10px 30px rgba(107, 33, 168, 0.25);
  }

  .btn-submit:hover:not(:disabled) {
    transform: translateY(-3px);
    background: var(--color-purple-mid);
    box-shadow: 0 16px 40px rgba(107, 33, 168, 0.35);
  }

  .btn-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .btn-spinner {
    display: none;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  .btn-submit.loading .btn-text    { display: none; }
  .btn-submit.loading .btn-spinner { display: block; }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .micro {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.3);
  }

  .form-error {
    font-size: 14px;
    color: #f87171;
    min-height: 20px;
  }

  /* ── Success state ── */

  .contact-success {
    display: none;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    padding: 60px 24px;
    animation: fadeUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .contact-success.visible {
    display: flex;
  }

  .success-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(124, 58, 237, 0.2);
    border: 1.5px solid rgba(124, 58, 237, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    color: var(--color-purple-mid);
  }

  .contact-success h3 {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .contact-success p {
    font-size: 17px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.65;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
