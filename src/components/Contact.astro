---
---

<section class="contact" id="cta" aria-labelledby="contact-heading">
  <div class="contact-inner">
    <h2 id="contact-heading" class="reveal">Ready to <em>Talk?</em></h2>
    <p class="reveal">20 minutes. No pitch. Just a real conversation about what you're building.</p>

    <div class="email-cta reveal">
      <div class="input-wrap">
        <input
          type="email"
          id="cta-email"
          placeholder="your@business.com"
          autocomplete="email"
          aria-label="Business email"
        />
        <p class="email-error" id="email-error"></p>
      </div>
      <button class="btn-book" id="open-booking">
        Book a Discovery Call →
      </button>
    </div>
    <p class="micro reveal">Free · 20 min · Google Meet</p>
  </div>
</section>

<script>
  const emailInput = document.getElementById('cta-email') as HTMLInputElement;
  const btn = document.getElementById('open-booking') as HTMLButtonElement;

  const errorEl = document.getElementById('email-error') as HTMLElement;

  function showError(msg: string) {
    errorEl.textContent = msg;
    emailInput.classList.add('invalid');
    emailInput.focus();
  }

  function clearError() {
    errorEl.textContent = '';
    emailInput.classList.remove('invalid');
  }

  btn.addEventListener('click', () => {
    const email = emailInput.value.trim();
    if (!email) { showError('Please enter your business email.'); return; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email)) { showError('Please enter a valid email address.'); return; }
    clearError();
    document.dispatchEvent(new CustomEvent('open-booking', { detail: { email } }));
  });

  emailInput.addEventListener('input', clearError);
  emailInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') btn.click();
  });
</script>

<style>
  .contact {
    background: var(--color-ink);
    color: #fff;
    padding: clamp(100px, 14vw, 180px) clamp(24px, 5vw, 72px);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .contact::before {
    content: '';
    position: absolute;
    bottom: -40%;
    left: 50%;
    transform: translateX(-50%);
    width: 80vw;
    height: 80vw;
    max-width: 1000px;
    max-height: 1000px;
    background: radial-gradient(circle, rgba(124, 58, 237, 0.2), transparent 62%);
    pointer-events: none;
  }

  .contact-inner {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  h2 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(44px, 8vw, 100px);
    letter-spacing: -0.035em;
    line-height: 1;
    margin-bottom: 4px;
  }

  h2 em {
    font-style: normal;
    color: var(--color-purple-mid);
  }

  .contact-inner > p {
    font-size: clamp(16px, 1.5vw, 18px);
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.65;
  }

  .email-cta {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    width: 100%;
    max-width: 560px;
    margin-top: 8px;
  }

  .input-wrap {
    flex: 1;
  }

  .email-error {
    font-size: 12px;
    color: #f87171;
    margin-top: 6px;
    min-height: 16px;
    text-align: left;
    padding-left: 4px;
  }

  input[type="email"] {
    font-family: var(--font-body);
    font-size: 15px;
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
    border: 1.5px solid rgba(255, 255, 255, 0.12);
    border-radius: 100px;
    padding: 15px 22px;
    width: 100%;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
  }

  input[type="email"]::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  input[type="email"]:focus {
    border-color: var(--color-purple-mid);
    background: rgba(124, 58, 237, 0.08);
  }

  input[type="email"].invalid {
    border-color: #f87171;
  }

  .btn-book {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    color: #fff;
    background: var(--color-purple);
    border: 1.5px solid transparent;
    padding: 15px 28px;
    border-radius: 100px;
    cursor: pointer;
    white-space: nowrap;
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.25s, background 0.25s;
    box-shadow: 0 10px 30px rgba(107, 33, 168, 0.25);
  }

  .btn-book:hover {
    transform: translateY(-2px);
    background: var(--color-purple-mid);
    box-shadow: 0 16px 40px rgba(107, 33, 168, 0.35);
  }

  .micro {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.25);
    margin-top: -4px;
  }

  @media (max-width: 560px) {
    .email-cta {
      flex-direction: column;
    }
    .btn-book {
      width: 100%;
    }
  }
</style>
